# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# SQLite database URL
DATABASE_URL=sqlite:///data/flip7.db

# Comma-separated list of allowed chat IDs (no spaces). Leave empty to allow all (dev mode).
# Example: ALLOWED_CHAT_IDS=-100123456,-100789012
ALLOWED_CHAT_IDS=

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info
