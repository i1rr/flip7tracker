# flip7bot (mmbot) environment — copy to .env and fill in. Keep .env gitignored
# and owner-only:  chmod 600 .env
#
# This file holds the bot token, the HMAC signing key, and the /flip7 slash
# token. Never commit the real .env.

# --- Mattermost connection (all required) ---
# Base URL of the Mattermost server reachable over the bridge.
MM_URL=http://172.28.0.1:8065
# Bot account token. Rotate in System Console -> Integrations -> Bot Accounts.
MM_BOT_TOKEN=
# Team name/slug that owns the flip7 channel and the slash command.
MM_TEAM=dom1k
# Channel name/slug for the flip7 channel (must be owner-only).
MM_CHANNEL=flip7

# --- Owner identity (at least one required) ---
# If only the username is set, the id is resolved at startup via GetUserByUsername.
OWNER_USER_ID=
OWNER_USERNAME=

# --- Secrets (required) ---
# Server-only signing key for inbound nav-state. Must be >= 32 bytes.
# Generate with:  openssl rand -hex 32
HMAC_KEY=
# Slash token captured from Mattermost when /flip7 is created (see scripts/register.sh).
SLASH_TOKEN_FLIP7=

# --- Storage (optional; default shown) ---
# SQLite database path inside the container (on the flip7_data volume).
DATABASE_URL=/data/flip7.db

# --- Inbound listener / integration URLs ---
# Bind the listener inside the container. 0.0.0.0:8068 is acceptable because the
# port is published only to the Mattermost bridge, never to the host.
LISTEN_ADDR=0.0.0.0:8068
# Base URL other bridge containers (Mattermost) use to reach this bot's
# /action, /dialog, and /slash endpoints. Required.
INTEGRATION_BASE_URL=http://172.28.0.5:8068

# --- Logging (optional; default shown) ---
# One of: debug, info, warn, error.
LOG_LEVEL=info
